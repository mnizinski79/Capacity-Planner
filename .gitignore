# ─── Node / npm ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Yarn v2+
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/
build/

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Prisma ───────────────────────────────────────────────────────────────────
src/generated/prisma/     # generated Prisma client (if output is overridden)
prisma/*.db               # SQLite database files (legacy / local)
prisma/*.db-journal

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Testing & coverage ───────────────────────────────────────────────────────
coverage/

# ─── Vercel / deployment ──────────────────────────────────────────────────────
.vercel

# ─── Misc ─────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
